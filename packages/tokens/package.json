{
  "name": "@basex-ui/tokens",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Design tokens as StyleX variables",
  "keywords": [
    "design-tokens",
    "stylex",
    "css-variables",
    "basex-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daviddow/BaseX-UI.git",
    "directory": "packages/tokens"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./presets": {
      "types": "./dist/presets.d.ts",
      "import": "./dist/presets.js"
    },
    "./oklch": {
      "types": "./dist/oklch.d.ts",
      "import": "./dist/oklch.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "peerDependencies": {
    "@stylexjs/stylex": ">=0.17.0"
  },
  "devDependencies": {
    "@stylexjs/stylex": "^0.17.5",
    "@stylexjs/babel-plugin": "^0.17.5",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
