{
  "name": "@basex-ui/cli",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "CLI for scaffolding BaseX UI into projects",
  "keywords": [
    "cli",
    "scaffolding",
    "basex-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daviddow/BaseX-UI.git",
    "directory": "packages/cli"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "basex-ui": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "templates"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@basex-ui/tokens": "workspace:*",
    "@basex-ui/styles": "workspace:*",
    "@basex-ui/intelligence": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
