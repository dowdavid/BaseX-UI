{
  "name": "@basex-ui/components",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Accessible React components on Base UI + StyleX",
  "keywords": [
    "react",
    "components",
    "base-ui",
    "stylex",
    "accessible",
    "basex-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daviddow/BaseX-UI.git",
    "directory": "packages/components"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./button": {
      "types": "./dist/button/index.d.ts",
      "import": "./dist/button/index.js"
    },
    "./accordion": {
      "types": "./dist/accordion/index.d.ts",
      "import": "./dist/accordion/index.js"
    },
    "./alert-dialog": {
      "types": "./dist/alert-dialog/index.d.ts",
      "import": "./dist/alert-dialog/index.js"
    },
    "./avatar": {
      "types": "./dist/avatar/index.d.ts",
      "import": "./dist/avatar/index.js"
    },
    "./checkbox": {
      "types": "./dist/checkbox/index.d.ts",
      "import": "./dist/checkbox/index.js"
    },
    "./checkbox-group": {
      "types": "./dist/checkbox-group/index.d.ts",
      "import": "./dist/checkbox-group/index.js"
    },
    "./collapsible": {
      "types": "./dist/collapsible/index.d.ts",
      "import": "./dist/collapsible/index.js"
    },
    "./autocomplete": {
      "types": "./dist/autocomplete/index.d.ts",
      "import": "./dist/autocomplete/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@basex-ui/styles": "workspace:*",
    "@basex-ui/tokens": "workspace:*",
    "lucide-react": "^0.575.0"
  },
  "peerDependencies": {
    "@stylexjs/stylex": ">=0.17.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "@stylexjs/babel-plugin": "^0.17.5",
    "@stylexjs/stylex": "^0.17.5",
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
