{
  "name": "@basex-ui/mcp-server",
  "version": "0.2.0",
  "type": "module",
  "license": "MIT",
  "description": "MCP server for AI agent component discovery",
  "keywords": [
    "ui",
    "component-library",
    "mcp",
    "model-context-protocol",
    "ai",
    "agents",
    "component-discovery",
    "typescript",
    "basex-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dowdavid/BaseX-UI.git",
    "directory": "packages/mcp-server"
  },
  "homepage": "https://github.com/dowdavid/BaseX-UI#readme",
  "bugs": {
    "url": "https://github.com/dowdavid/BaseX-UI/issues"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "basex-ui-mcp": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@basex-ui/intelligence": "workspace:*",
    "@basex-ui/tokens": "workspace:*",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
