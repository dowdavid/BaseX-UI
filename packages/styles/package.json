{
  "name": "@basex-ui/styles",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Theme definitions (light/dark) and utilities",
  "keywords": [
    "themes",
    "stylex",
    "basex-ui"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daviddow/BaseX-UI.git",
    "directory": "packages/styles"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@basex-ui/tokens": "workspace:*"
  },
  "peerDependencies": {
    "@stylexjs/stylex": ">=0.17.0"
  },
  "devDependencies": {
    "@stylexjs/stylex": "^0.17.5",
    "@stylexjs/babel-plugin": "^0.17.5",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  }
}
